# Copia este archivo como .env y ajusta los valores en la VM2 (backend)
#   cp .env.example .env
#   nano .env

# Puerto donde escucha la API
PORT=3000

# --- Conexión a la VM3 (servidor de base de datos) ---
# Sustituye DB_HOST por la IP que te dio "hostname -I" en la VM de la base de datos
DB_HOST=192.168.1.X
DB_PORT=3306
DB_USER=apiuser
DB_PASSWORD=Api12345*
DB_NAME=oficina
DB_CONNECTION_LIMIT=10
